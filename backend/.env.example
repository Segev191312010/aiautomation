# ── Interactive Brokers connection ──────────────────────────────────────────
# Running TWS and the bot on the same machine — connect directly via localhost.
# Port guide:
#   7497 = TWS live account
#   7496 = TWS paper account
#   4001 = IB Gateway live account
#   4002 = IB Gateway paper account
IBKR_HOST=127.0.0.1
IBKR_PORT=7496
IBKR_CLIENT_ID=1

# ── Safety ──────────────────────────────────────────────────────────────────
# Keep IS_PAPER=true until you are confident in your rules.
# When false, real money is at risk.
IS_PAPER=true

# ── Simulation mode ─────────────────────────────────────────────────────────
# SIM_MODE=true  → orders go to virtual account, NOT IBKR (fully offline)
# SIM_MODE=false → orders go to IBKR paper or live account
SIM_MODE=false
SIM_INITIAL_CASH=100000.0
SIM_COMMISSION=1.0

# ── Mock data ────────────────────────────────────────────────────────────────
# MOCK_MODE=true → use GBM-generated market data when IBKR is offline.
# The React dashboard will still show live-looking charts without IB Gateway.
MOCK_MODE=true

# ── Auto-reconnect ───────────────────────────────────────────────────────────
# Seconds between reconnect attempts when IBKR drops (0 = disabled)
RECONNECT_INTERVAL=30

# ── Bot behaviour ───────────────────────────────────────────────────────────
# How often the bot re-evaluates all rules (in seconds).
BOT_INTERVAL_SECONDS=60

# ── Database ────────────────────────────────────────────────────────────────
DB_PATH=trading_bot.db

# ── API server ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── React dashboard ──────────────────────────────────────────────────────────
# Build the SPA first: cd dashboard && npm install && npm run build
# Then it is served at http://localhost:8000/app
DASHBOARD_BUILD_DIR=../dashboard/dist
