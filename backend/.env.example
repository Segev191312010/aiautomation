# ── Interactive Brokers connection ──────────────────────────────────────────
# Running TWS and the bot on the same machine — connect directly via localhost.
# Port guide:
#   7496 = TWS live account
#   7497 = TWS paper account
#   4001 = IB Gateway live account
#   4002 = IB Gateway paper account
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ── Safety ──────────────────────────────────────────────────────────────────
# Keep IS_PAPER=true until you are confident in your rules.
# When false, real money is at risk.
IS_PAPER=true

# ── Simulation mode ─────────────────────────────────────────────────────────
# SIM_MODE=true  → orders go to virtual account, NOT IBKR (fully offline)
# SIM_MODE=false → orders go to IBKR paper or live account
SIM_MODE=false
SIM_INITIAL_CASH=100000.0
SIM_COMMISSION=1.0

# ── Auto-reconnect ───────────────────────────────────────────────────────────
# Seconds between reconnect attempts when IBKR drops (0 = disabled)
RECONNECT_INTERVAL=30

# ── Bot behaviour ───────────────────────────────────────────────────────────
# How often the bot re-evaluates all rules (in seconds).
BOT_INTERVAL_SECONDS=60

# ── Alert engine ──────────────────────────────────────────────────────────────
# How often the alert engine checks all enabled alerts (in seconds).
ALERT_CHECK_INTERVAL_SECONDS=30

# ── Database ────────────────────────────────────────────────────────────────
DB_PATH=trading_bot.db
WS_PUSH_INTERVAL_SECONDS=0.5
WS_CACHE_TTL_SECONDS=0.5

# Diagnostics (Market Diagnostic Dashboard merge)
ENABLE_MARKET_DIAGNOSTICS=false
DIAG_INTRADAY_INTERVAL_SECONDS=300
DIAG_LOCK_TTL_SECONDS=600
DIAG_NEWS_HOURS_DEFAULT=24
DIAG_NEWS_LIMIT_DEFAULT=200
DIAG_MARKET_MAP_DAYS_DEFAULT=5
DIAG_SCHEDULER_TIMEZONE=America/New_York

# ── API server ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── JWT / Auth ──────────────────────────────────────────────────────────────
# JWT_SECRET: shared secret for signing/verifying bearer tokens
JWT_SECRET=trading-dev-secret-MUST-SET-IN-ENV
# JWT_BOOTSTRAP_SECRET: required by POST /api/auth/token to issue demo tokens.
# Set this before exposing port 8000 to any network (LAN, ngrok, tunnel).
# The dashboard must send the same value in the X-Bootstrap-Secret header.
JWT_BOOTSTRAP_SECRET=

# ── React dashboard ──────────────────────────────────────────────────────────
# Build the SPA first: cd dashboard && npm install && npm run build
# Then it is served at http://localhost:8000/app
DASHBOARD_BUILD_DIR=../dashboard/dist
